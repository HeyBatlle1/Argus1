# Copy this file to .env.local and fill in your values.
#
# Without NEXT_PUBLIC_WS_URL the frontend runs in dev/mock mode —
# no real API calls, simulated responses, seed data in the UI.
#
# With NEXT_PUBLIC_WS_URL set the frontend connects to the Rust backend.
# Start the backend first: cargo run -- web (from Argus1/)

NEXT_PUBLIC_WS_URL=ws://localhost:9000/ws
